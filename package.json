{
  "name": "oh-my-copilot",
  "version": "4.11.4",
  "description": "Multi-agent orchestration system for Copilot CLI - Inspired by oh-my-opencode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "oh-my-copilot": "bridge/cli.cjs",
    "omc": "bridge/cli.cjs"
  },
  "files": [
    "dist",
    "agents",
    "bridge",
    "bridge/mcp-server.cjs",
    "bridge/team-bridge.cjs",
    "bridge/team.js",
    "bridge/cli.cjs",
    "bridge/runtime-cli.cjs",
    "commands",
    "hooks",
    "scripts",
    "skills",
    "templates",
    "docs",
    ".claude-plugin",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-skill-bridge.mjs && node scripts/build-mcp-server.mjs && node scripts/build-bridge-entry.mjs && npm run compose-docs && npm run build:runtime-cli && npm run build:cli",
    "build:bridge": "node scripts/build-skill-bridge.mjs",
    "build:codex": "echo '[deprecated] Codex MCP server removed in v5.0 - use tmux team workers instead'",
    "build:gemini": "echo '[deprecated] Gemini MCP server removed in v5.0 - use tmux team workers instead'",
    "build:bridge-entry": "node scripts/build-bridge-entry.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "build:runtime-cli": "node scripts/build-runtime-cli.mjs",
    "ask:codex": "./scripts/ask-codex.sh",
    "ask:gemini": "./scripts/ask-gemini.sh",
    "compose-docs": "node scripts/compose-docs.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "bench:prompts": "tsx benchmarks/run-all.ts",
    "bench:prompts:save": "tsx benchmarks/run-all.ts --save-baseline",
    "bench:prompts:compare": "tsx benchmarks/run-all.ts --compare",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "sync-metadata": "tsx scripts/sync-metadata.ts",
    "sync-metadata:verify": "tsx scripts/sync-metadata.ts --verify",
    "sync-metadata:dry-run": "tsx scripts/sync-metadata.ts --dry-run",
    "prepublishOnly": "npm run build && npm run compose-docs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@ast-grep/napi": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "jsonc-parser": "^3.3.1",
    "safe-regex": "^2.1.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/ui": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RobinNorberg/oh-my-copilot.git"
  },
  "homepage": "https://github.com/RobinNorberg/oh-my-copilot#readme",
  "bugs": {
    "url": "https://github.com/RobinNorberg/oh-my-copilot/issues"
  },
  "author": "Robin Norberg",
  "license": "MIT",
  "keywords": [
    "copilot",
    "copilot-cli",
    "ai",
    "agent",
    "multi-agent",
    "orchestration",
    "omc",
    "github",
    "llm"
  ],
  "publishConfig": {
    "access": "public"
  }
}
